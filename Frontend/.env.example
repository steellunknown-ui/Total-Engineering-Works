# ============================================================
# Frontend Environment Variables — TEMPLATE
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to git.
# ============================================================

# Email sending via Resend
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=noreply@tatvadynamics.com
RESEND_TO_EMAIL=your-company-email@tatvadynamics.com

# Public site URL (no trailing slash)
# Development: http://localhost:3000
# Production:  https://tatvadynamics.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenRouter API Key (for AI chatbot)
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# Backend API URL (only needed if frontend calls FastAPI directly)
# Local:  http://localhost:8000
# Office: http://192.168.1.x:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
